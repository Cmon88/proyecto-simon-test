# ==== Backend ====
NODE_ENV=development
PORT=4000
# Postgres (docker-compose uses these)
POSTGRES_USER=simon
POSTGRES_PASSWORD=simon
POSTGRES_DB=simon
DATABASE_URL=postgresql://simon:simon@postgres:5432/simon?schema=public

# JWT
JWT_SECRET=change-me-in-prod-please-at-least-32-chars
JWT_EXPIRES_IN=12h

# AI provider (Groq free tier — OpenAI-compatible)
# Get a key at https://console.groq.com
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=tu-api-key-aqui
AI_MODEL=llama-3.1-8b-instant
# If AI_API_KEY is empty, backend uses a deterministic mock streamer.

# CORS / Frontend URL for sockets
FRONTEND_ORIGIN=http://localhost:5173

# ==== Frontend (Vite) ====
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000
